				<munit:payload value="#[{}]" />
				<munit:attributes value='#[{&#10;  method: "GET",&#10;  requestPath: "/api/health",&#10;  headers: {}&#10;}]' />
			</munit:set-event>
			<flow-ref doc:name="Flow Reference" doc:id="cd468aa6-ef52-42ce-8c9b-600cbec08c8f" name="get:\health:gocs-inventory-papi-config"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-equals doc:name="Assert equals" doc:id="b0ab5315-37a2-418e-966b-df9d4364403b" actual="#[payload.status]" expected="UP"/>
		</munit:validation>
