	<munit:config name="health_check_test.xml" />
	<munit:test name="health_check_testTest" doc:id="41eea415-e634-432c-bbdb-bfb32e3373ac" >
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock when" doc:id="209c04e6-1e6a-41a9-9e70-e70ba72af37c" processor="os:retrieve">
				<munit-tools:then-return >
					<munit-tools:payload value='#[{&#10;  status: "UP",&#10;  api: "inventory-papi",&#10;  version: "v1"&#10;}]' />
